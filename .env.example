# Какой LLM-провайдер использовать: deepseek (по умолчанию) или gigachat.
LLM_PROVIDER=deepseek

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GigaChat (Sber) — https://developers.sber.ru/studio
GIGACHAT_AUTH_KEY=your_base64_auth_key_here

# ── RAG (поиск по базе документов) ────────────────────────────────────────────
# Требует установленного extra: pip install -e ".[rag]" и запущенного Ollama.
# RAG_ENABLED=true                       # включить RAG сразу на старте
# RAG_INDEX_PATH=~/rag-kotlin/index      # каталог с <strategy>.faiss/.meta.json
# RAG_STRATEGY=structural                # какая стратегия чанкинга (fixed|structural)
# RAG_TOP_K=5                            # сколько фрагментов оставить ПОСЛЕ фильтра/реранка
# Второй этап (rewrite → fetch → порог → реранк → top_k); всё меняется и на лету через /rag:
# RAG_FETCH_K=20                         # сколько кандидатов достать ДО фильтра/реранка
# RAG_MIN_SCORE=0.0                      # порог косинуса: чанки ниже отсекаются (0 = выкл)
# RAG_RERANKER=heuristic                 # реранкер: none | heuristic | llm
# RAG_REWRITE=false                      # переформулировать запрос через LLM перед поиском
